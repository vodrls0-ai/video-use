[
  {
    "start": 0.0,
    "end": 2.16,
    "text": "35세 부터 분위기 빠진다는 거"
  },
  {
    "start": 2.16,
    "end": 3.56,
    "text": "진짜 현실이네요"
  },
  {
    "start": 3.56,
    "end": 4.9,
    "text": "다리는 간으로지고"
  },
  {
    "start": 4.9,
    "end": 5.88,
    "text": "아이스 아름찌고"
  },
  {
    "start": 5.88,
    "end": 8.5,
    "text": "머리버도 자신감이 떨어졌어요"
  },
  {
    "start": 8.5,
    "end": 9.86,
    "text": "운동하면 되는 거 아니냐고요?"
  },
  {
    "start": 10.22,
    "end": 11.54,
    "text": "아이 키운으로 바팠고"
  },
  {
    "start": 11.54,
    "end": 13.18,
    "text": "현실에 치여 살았습니다"
  },
  {
    "start": 13.18,
    "end": 14.1,
    "text": "그러다 오늘 날"
  },
  {
    "start": 14.1,
    "end": 14.54,
    "text": "아빠"
  },
  {
    "start": 14.54,
    "end": 15.18,
    "text": "왜?"
  },
  {
    "start": 15.8,
    "end": 18.24,
    "text": "최초 아빠, 아빠가 왜 안 있어?"
  },
  {
    "start": 18.42,
    "end": 19.32,
    "text": "그때 부터였습니다"
  },
  {
    "start": 19.32,
    "end": 20.78,
    "text": "패션에 대해 공부한 게"
  },
  {
    "start": 20.78,
    "end": 22.36,
    "text": "출근한 티와 출인인해서"
  },
  {
    "start": 22.36,
    "end": 24.06,
    "text": "처진 몸을 잡아줄 수 있는"
  },
  {
    "start": 24.06,
    "end": 25.88,
    "text": "원단이 탄탄한 티셔츠로"
  },
  {
    "start": 25.88,
    "end": 28.32,
    "text": "다리가 길어볼 수 있는 청바지로"
  },
  {
    "start": 28.32,
    "end": 29.1,
    "text": "텐몸인데"
  },
  {
    "start": 29.1,
    "end": 31.16,
    "text": "분위기는 완전 달라지더라고요"
  },
  {
    "start": 31.16,
    "end": 33.12,
    "text": "결국 아이가 문제가 아니라"
  },
  {
    "start": 33.12,
    "end": 34.56,
    "text": "분위기 문제였습니다"
  },
  {
    "start": 34.56,
    "end": 37.98,
    "text": "제가 아이에게 칭찬 받을 수 있을 때까지"
  },
  {
    "start": 37.98,
    "end": 40.0,
    "text": "빨라워하고 지켜봐 주세요"
  }
]